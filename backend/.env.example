# Spotify OAuth — https://developer.spotify.com/dashboard → Create App
# Redirect URI to set in Spotify dashboard: http://127.0.0.1:3001/auth/callback
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3001/auth/callback

# Session — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate_a_random_64_char_hex_string

# Gemini API — https://aistudio.google.com → Get API Key
# Optional: AI personality analysis feature will be disabled if not set
GEMINI_API_KEY=your_gemini_api_key

# Optional
PORT=3001
CLIENT_URL=http://localhost:3000

# Production'da NODE_ENV=production ayarla: secure cookie, kısıtlı CORS,
# ve backend frontend/dist'i tek origin'den static serve eder
NODE_ENV=development
